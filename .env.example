# Copy to .env.local for local dev. NEVER commit .env.local.

# Public — exposed to client
NEXT_PUBLIC_SITE_URL=https://cykrus.at
NEXT_PUBLIC_CHAT_API=/api/chat

# Server-only
ANTHROPIC_API_KEY=sk-ant-xxx          # Cykra-Brain. Wird auch als Worker-Secret gespeichert.
ALERT_EMAIL=info@cykrus.at

# Cloudflare (für lokales Wrangler dev)
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_API_TOKEN=xxx
